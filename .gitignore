# PlatformIO
.pio/
.pioenvs/
.piolibdeps/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/

# Secrets — never commit WiFi creds, API keys, tokens.
# (Ground Truth provisions WiFi at runtime; no secrets.h is expected. If one
#  appears during debugging, it stays ignored.)
include/secrets.h
src/secrets.h
secrets.h
*.local.h

# Recipient personalization (boot-splash name) — keep PII out of the public repo.
include/personalization.h

# Owner's-guide PRINT copies — filled with a device's passwords + MAC addresses, so they stay
# local. The blank source template (docs/OWNERS-GUIDE.md) stays committed.
docs/OWNERS-GUIDE.html
docs/OWNERS-GUIDE*.pdf

# OS
.DS_Store

.fonttool/
